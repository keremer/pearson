<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="httpPlatformHandler" 
           path="*" 
           verb="*" 
           modules="httpPlatformHandler" 
           resourceType="Unspecified"
           requireAccess="Script" />
    </handlers>
    <httpPlatform processPath="C:\inGitHub\pythonapps\portal\.venv\Scripts\python.exe"
                  arguments="C:\inGitHub\pythonapps\portal\crminaec\serve.py"
                  stdoutLogEnabled="true"
                  stdoutLogFile="C:\inetpub\logs\crminaec.log"
                  startupTimeLimit="60">
      <environmentVariables>
        <environmentVariable name="PORT" value="%HTTP_PLATFORM_PORT%" />
        <environmentVariable name="GOOGLE_CLIENT_SECRETS" value="C:\crminaec\secrets\client_secret_2_15822092818-45h4l1e3bg53sah1totakiqr8p4b0585.apps.googleusercontent.com.json" />
        <environmentVariable name="PYTHONPATH" value="C:\inGitHub\pythonapps\portal" />
        <environmentVariable name="PYTHONIOENCODING" value="utf-8" />
        <environmentVariable name="SCRIPT_NAME" value="/crminaec" />
      </environmentVariables>
    </httpPlatform>
  </system.webServer>
</configuration>