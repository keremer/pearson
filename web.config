<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="PythonHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified"
           requireAccess="Script" />
    </handlers>

    <httpPlatform
        processPath="C:\Users\kerem\OneDrive\Development\TrustedFolderforActiveContent\PythonProjects\PEARSON\.venv\Scripts\python.exe"
        arguments="C:\Users\kerem\OneDrive\Development\TrustedFolderforActiveContent\PythonProjects\PEARSON\serve.py"
        stdoutLogEnabled="true"
        stdoutLogFile="C:\inetpub\logs\pearson_std.log"
        startupTimeLimit="60"
        requestTimeout="00:02:00">
      <environmentVariables>
        <environmentVariable name="PORT" value="%HTTP_PLATFORM_PORT%" />
      </environmentVariables>
    </httpPlatform>
  </system.webServer>
</configuration>